# ──────────────────────────────────────────────────────────────────────
#  OmniRoute — Dokploy .env
#  Copy to .env (or paste into Dokploy → Environment tab). Do NOT commit .env.
# ──────────────────────────────────────────────────────────────────────

# ── Public URL (must be the exact HTTPS domain Dokploy/Traefik serves) ──
BASE_URL=https://omni.tux.bd
NEXT_PUBLIC_BASE_URL=https://omni.tux.bd

# ── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=20128
DATA_DIR=/app/data

# Behind Traefik TLS termination → secure cookies.
AUTH_COOKIE_SECURE=true

# ── Secrets ─────────────────────────────────────────────────────────────
# For a FRESH deploy: keep these generated values (or regenerate with
#   openssl rand -base64 36
# For MIGRATION from Fly: if you import the old /app/data volume, you MUST
# reuse the SAME values the Fly instance used (check `fly secrets list`),
# otherwise encrypted provider credentials/OAuth tokens in the DB won't
# decrypt. Fly's fly.toml set none of these, so they may have been left at
# defaults or set via `fly secrets` — verify before importing data.
JWT_SECRET=3cS3VBhvwfOSZQyjQYjxeCDOTZznt5h8M0CiXlO4X5Mh
API_KEY_SECRET=aqiQjeUJy6tZIU3Rn22wlVukYKFdjgO0IR48UePgyugV
STORAGE_ENCRYPTION_KEY=XzUEMD3dWkqqLULYWIjp8wSqTuqCOrSCJARuN0soUrG1
STORAGE_ENCRYPTION_KEY_VERSION=v1
MACHINE_ID_SALT=nFBi9eqdwCENC43W8XjI22pyXkMzQuwQ7tbyqnjlARnl

# Initial admin password for first boot (change in UI after login).
INITIAL_PASSWORD=ZiNTSMCpxrCzfitEV4kGs9Djx8YJgRNUAVF9iHRKFAIO

# ── Provider API keys (optional) ────────────────────────────────────────
# Leave empty if you configure providers in the UI / import existing config.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
